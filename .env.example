# ============================================================
# macromalt 자동화 시스템 - 환경 변수 설정 템플릿
# ============================================================
# 사용법:
#   cp .env.example .env
#   .env 파일에 실제 값을 입력하세요.
# 주의: .env는 절대 깃허브에 올리지 마세요! (.gitignore 포함됨)
# ============================================================

# ── [OpenAI] ─────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# ── [Gemini] ─────────────────────────────────────────────────
# https://aistudio.google.com/api-keys
GEMINI_API_KEY=AIza...

# ── [OpenDART] ───────────────────────────────────────────────
# https://opendart.fss.or.kr/ 에서 무료 발급 (인증키 신청/관리)
# 발급 후 40자리 키를 아래에 입력하세요.
# Phase 5-A: list.json / fnlttSinglAcnt / company.json 연동에 사용됩니다.
DART_API_KEY=

# ── [WordPress] ──────────────────────────────────────────────
# 워드프레스 관리자 계정 또는 앱 비밀번호(Application Password)
WORDPRESS_SITE_URL=https://macromalt.com
WORDPRESS_USERNAME=your_wp_username
WORDPRESS_PASSWORD=your_app_password

# ── [한국경제 컨센서스] ───────────────────────────────────────
HANKYUNG_USERNAME=your_email@example.com
HANKYUNG_PASSWORD=your_password

# ── [WordPress 카테고리 ID] ───────────────────────────────────
# 비워두면 기본값(ID=2) 사용
WP_CATEGORY_ANALYSIS=
WP_CATEGORY_PICKS=
WP_CATEGORY_DEFAULT=

# ── [수집 설정] ───────────────────────────────────────────────
# 수집 주기(분 단위), 기본값 60
SCRAPE_INTERVAL_MINUTES=60

# ── [Unsplash] ───────────────────────────────────────────────
# https://unsplash.com/developers → Access Key
UNSPLASH_ACCESS_KEY=
